{
    "tasks": {
        "dev": "deno task bundle && (deno task bundle:dev & deno task start:dev)",
        "start": "deno run -A --env-file app/serve.ts",
        "start:dev": "deno run -A --env-file --watch app/serve.ts",
        "bundle": "rm -rf app/frontend/dist && deno bundle --outdir=app/frontend/dist ./app/frontend/app.ts",
        "bundle:dev": "deno task bundle && deno bundle --outdir=app/frontend/dist --watch ./app/frontend/app.ts",
        "generate": "deno task generate:db",
        "generate:db": "deno run -A --env-file ./app/database/generate.ts",
        "check": "deno check app"
    },
    "unstable": ["raw-imports"],
    "compilerOptions": {
        "lib": ["esnext", "deno.window", "dom", "dom.iterable"]
    },
    "fmt": {
        "lineWidth": 120,
        "indentWidth": 4
    },
    "lint": {
        "rules": {
            "exclude": ["no-namespace"]
        }
    },
    "imports": {
        "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
        "@kysely/kysely": "jsr:@kysely/kysely@^0.28.16",
        "@maheshbansod/kysely-codegen": "jsr:@maheshbansod/kysely-codegen@^0.1.1",
        "@marshift/kysely-deno-sqlite3": "jsr:@marshift/kysely-deno-sqlite3@^1.0.0",
        "@nomadshiba/codec": "jsr:@nomadshiba/codec@^0.2.1",
        "@std/http": "jsr:@std/http@^1.1.0",
        "@std/path": "jsr:@std/path@^1.1.4",
        "@std/uuid": "jsr:@std/uuid@^1.1.1",
        "~/": "./app/"
    }
}
