{
    "tasks": {
        "prepare": "deno task generate",
        "dev": "deno task bundle && (deno task dev:bundle & deno task dev:start)",
        "dev:start": "deno run -A --no-prompt --env-file --watch app/serve.ts",
        "dev:bundle": "deno bundle --outdir=app/frontend/dist --watch ./app/frontend/app.ts",
        "start": "deno run -A --no-prompt --env-file app/serve.ts",
        "bundle": "rm -rf app/frontend/dist && deno bundle --outdir=app/frontend/dist ./app/frontend/app.ts",
        "generate": "deno task generate:db",
        "generate:db": "deno run -A --env-file ./app/backend/database/generate.ts",
        "check": "deno check app"
    },
    "unstable": ["raw-imports", "worker-options"],
    "compilerOptions": {
        "lib": ["esnext", "deno.window", "dom", "dom.iterable"]
    },
    "fmt": {
        "lineWidth": 140,
        "indentWidth": 4
    },
    "lint": {
        "rules": {
            "exclude": ["no-namespace"]
        }
    },
    "imports": {
        "@noble/hashes": "jsr:@noble/hashes@^2.2.0",
        "@pomdtr/sqlite": "jsr:@pomdtr/sqlite@^3.9.1",
        "@purifyjs/core": "jsr:@purifyjs/core@0.5.0-preview.5",
        "@std/async": "jsr:@std/async@^1.5.0",
        "@std/encoding": "jsr:@std/encoding@^1.0.11",
        "@kysely/kysely": "jsr:@kysely/kysely@^0.28.16",
        "@maheshbansod/kysely-codegen": "jsr:@maheshbansod/kysely-codegen@^0.1.1",
        "@nomadshiba/codec": "jsr:@nomadshiba/codec@0.5.0-preview.6",
        "@std/cli": "jsr:@std/cli@^1.0.31",
        "@std/http": "jsr:@std/http@^1.1.0",
        "@std/path": "jsr:@std/path@^1.1.4",
        "@std/uuid": "jsr:@std/uuid@^1.1.1",
        "~/": "./app/"
    }
}
